# ============================================================
# Copy this file to .env and fill in the values.
# .env is never committed to git (it's in .gitignore).
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financedb
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=changeme          # change this to anything you like

# --- Storage backend ---
# "local"  = plain files on disk inside ./storage/  ← start here, zero setup
# "minio"  = MinIO Docker container (localhost:9000) ← local dev with S3 API
# "b2"     = Backblaze B2 (S3-compatible cloud)      ← production
# "s3"     = real AWS S3                             ← alternative cloud
STORAGE_BACKEND=local

# Local backend path (only used when STORAGE_BACKEND=local)
STORAGE_ROOT=storage

# MinIO credentials (only used when STORAGE_BACKEND=minio)
# These are also the login for the browser UI at http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# Backblaze B2 credentials (only used when STORAGE_BACKEND=b2)
# Create an app key at https://secure.backblaze.com/b2_buckets.htm
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=

# Bucket name — used by MinIO, B2, and S3 backends
S3_BUCKET=finance-data

# AWS credentials (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- News ---
NEWS_API_KEY=your_newsapi_key_here

# --- Polygon.io (optional, for real-time data later) ---
POLYGON_API_KEY=

# --- Sentiment model (Phase 3) ---
SENTIMENT_MODEL_NAME=ProsusAI/finbert
SENTIMENT_MODEL_VERSION=finbert-finetuned-v1
SENTIMENT_BATCH_SIZE=32
SENTIMENT_MAX_LENGTH=512

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://finance_user:changeme@localhost:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=           # generate with the command below
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
